<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Welcome Email</title>
</head>

<body style="margin:0; padding:0; background-color:#f4f4f7; font-family: Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f7; padding:20px;">
    <tr>
      <td align="center">

        <!-- Card Container -->
        <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:10px; padding:30px; box-shadow:0 4px 10px rgba(0,0,0,0.05);">

          <!-- Header -->
          <tr>
            <td align="center" style="padding-bottom:20px;">
              <h1 style="color:#FF5A5F; margin:0;">Welcome 🎉</h1>
            </td>
          </tr>

          <!-- Greeting -->
          <tr>
            <td style="font-size:16px; color:#333;">
              <p style="margin:0;">Hi <strong>{{name}}</strong>,</p>
            </td>
          </tr>

          <!-- Message -->
          <tr>
            <td style="font-size:15px; color:#555; padding-top:15px; line-height:1.6;">
              <p>
                Welcome to <strong>Airbnb</strong>! We're thrilled to have you on board.
              </p>
              <p>
                If you have any questions or need assistance, feel free to reach out to our support team anytime.
              </p>
            </td>
          </tr>

          <!-- CTA Button -->
          <tr>
            <td align="center" style="padding:25px 0;">
              <a href="#" 
                 style="background-color:#FF5A5F; color:white; padding:12px 25px; text-decoration:none; border-radius:5px; font-size:14px;">
                Get Started
              </a>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="font-size:13px; color:#999; text-align:center; border-top:1px solid #eee; padding-top:15px;">
              <p style="margin:0;">Best regards,<br/>The Airbnb Team</p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>